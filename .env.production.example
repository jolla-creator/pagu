# Production Environment Variables for Pagù on Vercel

# === DATABASE ===
# Use Supabase PostgreSQL connection string (transaction pooler, port 6543)
DATABASE_URL="postgresql://postgres.xxxxxxxxxxxx:YOUR_PASSWORD@aws-xx-xxxx-x.pooler.supabase.com:6543/postgres"

# === AUTHENTICATION ===
# Generate a strong random string for JWT secret (min 32 chars)
JWT_SECRET="YOUR_STRONG_RANDOM_SECRET_HERE_MIN_32_CHARS"

# Legacy dashboard password (can be removed after JWT migration)
DASHBOARD_PASSWORD="CHANGE_THIS_PASSWORD"

# === STRIPE (Production Keys) ===
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY="sk_live_YOUR_LIVE_KEY_HERE"
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_live_YOUR_LIVE_KEY_HERE"

# Webhook secret: https://dashboard.stripe.com/webhooks
STRIPE_WEBHOOK_SECRET="whsec_YOUR_WEBHOOK_SECRET_HERE"

# Subscription price IDs: https://dashboard.stripe.com/prices
STRIPE_SUBSCRIPTION_PRICE_ID="price_BASIC_MONTHLY_PRICE_ID"
STRIPE_SUBSCRIPTION_PRO_PRICE_ID="price_PRO_MONTHLY_PRICE_ID"

# === APP CONFIGURATION ===
NEXT_PUBLIC_APP_URL="https://your-domain.vercel.app"

# === SUPABASE (if using) ===
# Supabase project reference (for MCP, etc.)
SUPABASE_PROJECT_REF="xxxxxxxxxxxx"

# === OPTIONAL: MONITORING ===
# SENTRY_DSN=""
# NEXT_PUBLIC_GA_ID=""
